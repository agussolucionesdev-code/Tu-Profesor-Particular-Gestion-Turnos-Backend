PORT=4100
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/tu-profesor-turnos
# Optional: use a non-SRV Atlas URI if your local DNS blocks mongodb+srv lookups.
MONGO_DIRECT_URI=
USE_MEMORY_DB=false
# Development only. Production still fails fast if MongoDB is unavailable.
MONGO_FALLBACK_TO_MEMORY=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=0

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
JWT_ISSUER=tu-profesor-particular-backend
JWT_AUDIENCE=tu-profesor-particular-admin
ALLOW_INSECURE_JWT_SECRET=false
# En desarrollo se permiten localhost/127.0.0.1 en cualquier puerto.
# Usa CORS_ORIGIN/FRONTEND_URL para frontends remotos o entornos productivos.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
PUBLIC_LOOKUP_RATE_LIMIT_MAX=40
PUBLIC_MUTATION_RATE_LIMIT_MAX=30
TRUST_PROXY=1
APP_TIME_ZONE=America/Argentina/Buenos_Aires
MAX_AVAILABILITY_RANGE_DAYS=120
SERVER_REQUEST_TIMEOUT_MS=15000
SERVER_HEADERS_TIMEOUT_MS=20000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000

ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

GOOGLE_SHEET_ID=
GOOGLE_SHEET_TITLE=Reservas
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

EMAIL_USER=
EMAIL_PASS=
OWNER_NOTIFICATION_EMAIL=
