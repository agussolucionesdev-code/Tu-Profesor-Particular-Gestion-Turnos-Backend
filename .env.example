PORT=4100
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/tu-profesor-turnos
USE_MEMORY_DB=false
MONGO_FALLBACK_TO_MEMORY=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
FRONTEND_URL=http://localhost:5174
RATE_LIMIT_MAX=200
TRUST_PROXY=1
APP_TIME_ZONE=America/Argentina/Buenos_Aires

ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

GOOGLE_SHEET_ID=
GOOGLE_SHEET_TITLE=Reservas
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

EMAIL_USER=
EMAIL_PASS=
OWNER_NOTIFICATION_EMAIL=
